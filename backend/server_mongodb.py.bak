@api_router.get("/auctions/{auction_id}")
async def get_auction(auction_id: str):
    """Get auction details with all bids"""
    auction = await db.auctions.find_one({"_id": ObjectId(auction_id)})
    if not auction:
        raise HTTPException(status_code=404, detail="Auction not found")
    
    return {"auction": serialize_doc(auction)}

@api_router.post("/auctions/bid")
async def place_auction_bid(bid_data: AuctionBid, user_id: str):
    """Buyer places bid on auction (highest bid wins)"""
    user = await db.users.find_one({"_id": ObjectId(user_id)})
    if not user:
        raise HTTPException(status_code=404, detail="User not found")
    
    if user.get("business_type") != "buyer":
        raise HTTPException(status_code=403, detail="Only buyers can bid on auctions")
    
    auction = await db.auctions.find_one({"_id": ObjectId(bid_data.auction_id)})
    if not auction:
        raise HTTPException(status_code=404, detail="Auction not found")
    
    if auction["ends_at"] < datetime.utcnow():
        raise HTTPException(status_code=400, detail="Auction has ended")
    
    # Ensure bid is higher than current highest
    current_highest = auction.get("base_price", 0)
    if auction.get("bids"):
        current_highest = max([b["bid_amount"] for b in auction["bids"]])
    
    if bid_data.bid_amount <= current_highest:
        raise HTTPException(status_code=400, detail="Bid must be higher than current highest bid")
    
    bid = {
        "bidder_id": user_id,
        "bidder_name": user["company_name"],
        "bid_amount": bid_data.bid_amount,
        "bid_time": datetime.utcnow()
    }
    
    await db.auctions.update_one(
        {"_id": ObjectId(bid_data.auction_id)},
        {"$push": {"bids": bid}}
    )
    
    # Broadcast to all connected clients
    await manager.broadcast(bid_data.auction_id, {
        "type": "new_bid",
        "auction_id": bid_data.auction_id,
        "bid": serialize_doc(bid)
    })
    
    return {"success": True, "message": "Bid placed successfully"}

# ==================== USER PROFILE & RATINGS ====================

@api_router.get("/users/{user_id}/profile")
async def get_user_profile(user_id: str):
    """Get user public profile"""
    user = await db.users.find_one({"_id": ObjectId(user_id)})
    if not user:
        raise HTTPException(status_code=404, detail="User not found")
    
    # Get ratings
    ratings = await db.ratings.find({"rated_user_id": user_id}).to_list(100)
    
    avg_rating = 0
    if ratings:
        avg_rating = sum([r["rating"] for r in ratings]) / len(ratings)
    
    return {
        "profile": {
            "company_name": user["company_name"],
            "location": user["location"],
            "business_type": user["business_type"],
            "verified": user.get("verified", False),
            "rating": round(avg_rating, 1),
            "total_trades": user.get("total_trades", 0),
            "member_since": user["created_at"].strftime("%B %Y")
        }
    }

@api_router.post("/ratings/create")
async def create_rating(rating_data: RatingCreate, user_id: str):
    """Create rating after trade completion"""
    rating_dict = {
        **rating_data.dict(),
        "rater_id": user_id,
        "created_at": datetime.utcnow()
    }
    
    await db.ratings.insert_one(rating_dict)
    
    return {"success": True, "message": "Rating submitted successfully"}

@api_router.get("/user/transactions")
async def get_user_transactions(user_id: str):
    """Get user's active contracts and transaction history"""
    user = await db.users.find_one({"_id": ObjectId(user_id)})
    if not user:
        raise HTTPException(status_code=404, detail="User not found")
    
    is_buyer = user.get("business_type") == "buyer"
    active_contracts = []
    transaction_history = []
    
    if is_buyer:
        # Buyer: Get their tenders with bids
        tenders = await db.tenders.find({
            "buyer_id": user_id,
            "bids": {"$exists": True, "$ne": []}
        }).to_list(100)
        
        for tender in tenders:
            for bid in tender.get("bids", []):
                contract_data = {
                    "variety": tender.get("variety"),
                    "size": tender.get("size"),
                    "quantity": float(bid.get("quantity_accepted", 0)),
                    "rate": float(tender.get("buyer_rate", 0)),
                    "status": bid.get("status", "quality_check"),
                    "counterparty_name": bid.get("bidder_name"),
                    "delivery_location": tender.get("delivery_location"),
                    "date": bid.get("bid_time")
                }
                
                if bid.get("status") == "quality_check":
                    active_contracts.append(contract_data)
                else:
                    transaction_history.append(contract_data)
    else:
        # Seller: Get all tenders they have bid on
        all_tenders = await db.tenders.find({
            "bids.bidder_id": user_id
        }).to_list(100)
        
        for tender in all_tenders:
            # Get buyer info
            buyer = await db.users.find_one({"_id": ObjectId(tender["buyer_id"])})
            buyer_name = buyer.get("company_name", "Unknown") if buyer else "Unknown"
            
            for bid in tender.get("bids", []):
                if bid.get("bidder_id") == user_id:
                    contract_data = {
                        "variety": tender.get("variety"),
                        "size": tender.get("size"),
                        "quantity": float(bid.get("quantity_accepted", 0)),
                        "rate": float(tender.get("buyer_rate", 0)),
                        "status": bid.get("status", "quality_check"),
                        "counterparty_name": buyer_name,
                        "delivery_location": tender.get("delivery_location"),
                        "date": bid.get("bid_time")
                    }
                    
                    if bid.get("status") == "quality_check":
                        active_contracts.append(contract_data)
                    else:
                        transaction_history.append(contract_data)
    
    # Sort by date (newest first)
    active_contracts.sort(key=lambda x: x.get("date") or datetime.min, reverse=True)
    transaction_history.sort(key=lambda x: x.get("date") or datetime.min, reverse=True)
    
    return {
        "active_contracts": serialize_doc(active_contracts),
        "transaction_history": serialize_doc(transaction_history)
    }

# ==================== MANDI PRICES ====================

@api_router.get("/mandi/prices")
async def get_mandi_prices(state: Optional[str] = None):
    """Get mandi prices from database"""
    query = {}
    if state:
        query["state"] = state
    
    prices = await db.mandi_prices.find(query).sort("updated_at", -1).to_list(100)
    
    # If no prices in DB, return empty list
    if not prices:
        return {"prices": []}
    
    return {"prices": serialize_doc(prices)}

