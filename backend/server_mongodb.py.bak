@api_router.post("/auctions/create")
async def create_auction(auction_data: AuctionCreate, user_id: str):
    """Seller creates a forward auction with fixed 24-hour deadline"""
    user = await db.users.find_one({"_id": ObjectId(user_id)})
    if not user:
        raise HTTPException(status_code=404, detail="User not found")
    
    if user.get("business_type") != "seller":
        raise HTTPException(status_code=403, detail="Only sellers can create auctions")
    
    # Fixed 24-hour deadline
    auction_dict = {
        **auction_data.dict(),
        "seller_id": user_id,
        "seller_name": user["company_name"],
        "status": "active",
        "bids": [],
        "created_at": datetime.utcnow(),
        "ends_at": datetime.utcnow() + timedelta(hours=24)
    }
    
    result = await db.auctions.insert_one(auction_dict)
    auction_dict['_id'] = str(result.inserted_id)
    
    return {"success": True, "auction": serialize_doc(auction_dict)}

