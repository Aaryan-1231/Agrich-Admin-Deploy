# Push Notification Helper Functions
async def send_push_notification(push_token: str, title: str, body: str, data: dict = None):
    """Send a push notification via Expo Push Service"""
    try:
        async with httpx.AsyncClient() as client:
            response = await client.post(
                "https://exp.host/--/api/v2/push/send",
                json={
                    "to": push_token,
                    "sound": "default",
                    "title": title,
                    "body": body,
                    "data": data or {}
                },
                headers={
                    "Accept": "application/json",
                    "Content-Type": "application/json"
                },
                timeout=10.0
            )
            result = response.json()
            logging.info(f"Push notification sent: {result}")
            return result
    except Exception as e:
        logging.error(f"Failed to send push notification: {e}")
        return None

async def send_notification_to_user(user_id: str, title: str, body: str, data: dict = None):
    """Send notification to a specific user"""
    user_token = await db.push_tokens.find_one({"user_id": user_id})
    if user_token and user_token.get("push_token"):
        return await send_push_notification(user_token["push_token"], title, body, data)
    return None

async def send_notification_to_all_sellers(title: str, body: str, data: dict = None):
    """Send notification to all approved sellers"""
    sellers = await db.users.find({
        "business_type": "seller",
        "approved": True
    }).to_list(1000)
    
    for seller in sellers:
        await send_notification_to_user(str(seller["_id"]), title, body, data)

async def send_notification_to_all_buyers(title: str, body: str, data: dict = None):
    """Send notification to all approved buyers"""
    buyers = await db.users.find({
        "business_type": "buyer",
        "approved": True
    }).to_list(1000)
    
    for buyer in buyers:
        await send_notification_to_user(str(buyer["_id"]), title, body, data)

# ==================== AUTH ENDPOINTS ====================

@api_router.post("/auth/send-otp")
async def send_otp(request: SendOTPRequest):
    """Mock OTP - In production, integrate with Firebase"""
    # For MVP, we just return success. Any 6-digit code will work in verify
    return {"success": True, "message": "OTP sent successfully"}

@api_router.post("/auth/verify-otp")
async def verify_otp(request: VerifyOTPRequest):
    """Mock OTP verification - any 6-digit code works (or Firebase verified)"""
    if len(request.otp) != 6:
        raise HTTPException(status_code=400, detail="Invalid OTP")
    
    # Check if user exists
    user = await db.users.find_one({"phone": request.phone})
    
    if not user:
        # New user - return flag to complete registration
        return {
            "success": True,
            "new_user": True,
            "phone": request.phone
        }
    
    # If Firebase UID is provided, update the user record
    if request.firebase_uid:
        await db.users.update_one(
            {"_id": user["_id"]},
            {"$set": {"firebase_uid": request.firebase_uid}}
        )
    
    # Check if user is approved by admin
    if not user.get("approved", False):
        return {
            "success": False,
            "pending_approval": True,
            "message": "Your account is pending admin approval. Please wait for approval."
        }
    
    # Existing user - return token and user data
    token = f"mock_token_{request.phone}"
    return {
        "success": True,
        "new_user": False,
        "token": token,
        "user": serialize_doc(user)
    }

@api_router.post("/auth/register")
async def register_user(user_data: UserCreate):
    """Complete user registration"""
    existing = await db.users.find_one({"phone": user_data.phone})
    if existing:
        raise HTTPException(status_code=400, detail="User already exists")
    
    user_dict = {
        **user_data.dict(),
        "kyc_status": "pending",
        "verified": False,
        "approved": False,  # Users need admin approval to login
        "rating": 0,
        "total_trades": 0,
        "created_at": datetime.utcnow()
    }
    
    result = await db.users.insert_one(user_dict)
    user_dict['_id'] = str(result.inserted_id)
    
    return {
        "success": True,
        "pending_approval": True,
        "message": "Registration successful! Your account is pending admin approval. You will be able to login once approved."
    }

# ==================== PUSH NOTIFICATION ENDPOINTS ====================

@api_router.post("/notifications/register-token")
async def register_push_token(token_data: PushTokenRegister):
    """Register or update a user's push notification token"""
    # Upsert the token - update if exists, insert if not
    await db.push_tokens.update_one(
        {"user_id": token_data.user_id},
        {
            "$set": {
                "push_token": token_data.push_token,
                "platform": token_data.platform,
                "updated_at": datetime.utcnow()
            }
        },
        upsert=True
    )
    return {"success": True, "message": "Push token registered successfully"}

@api_router.delete("/notifications/unregister-token")
async def unregister_push_token(user_id: str):
    """Remove a user's push notification token (e.g., on logout)"""
    await db.push_tokens.delete_one({"user_id": user_id})
    return {"success": True, "message": "Push token removed successfully"}

