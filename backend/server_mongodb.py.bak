# ==================== TENDER ENDPOINTS (Reverse Auction) ====================

@api_router.post("/tenders/create")
async def create_tender(tender_data: TenderCreate, user_id: str):
    """Buyer creates a reverse tender with fixed 24-hour deadline"""
    user = await db.users.find_one({"_id": ObjectId(user_id)})
    if not user:
        raise HTTPException(status_code=404, detail="User not found")
    
    if user.get("business_type") != "buyer":
        raise HTTPException(status_code=403, detail="Only buyers can create tenders")
    
    # Fixed 24-hour deadline
    tender_dict = {
        **tender_data.dict(),
        "buyer_id": user_id,
        "buyer_name": user["company_name"],
        "status": "active",
        "bids": [],
        "created_at": datetime.utcnow(),
        "ends_at": datetime.utcnow() + timedelta(hours=24)
    }
    
    result = await db.tenders.insert_one(tender_dict)
    tender_dict['_id'] = str(result.inserted_id)
    
    # Send push notification to all approved sellers about new tender
    await send_notification_to_all_sellers(
        title="New Tender Available!",
        body=f"{tender_data.variety} - {tender_data.quantity_mt} MT @ ₹{tender_data.buyer_rate}/kg",
        data={
            "type": "new_tender",
            "tender_id": str(result.inserted_id),
            "variety": tender_data.variety,
            "quantity": tender_data.quantity_mt,
            "rate": tender_data.buyer_rate
        }
    )
    
    return {"success": True, "tender": serialize_doc(tender_dict)}

@api_router.get("/tenders/active")
async def get_active_tenders(user_id: Optional[str] = None):
    """Get active tenders - Buyers see only their own, Sellers see all"""
    query = {
        "status": "active",
        "ends_at": {"$gt": datetime.utcnow()}
    }
    
    # If user_id provided, check if buyer and filter to their own tenders
    if user_id:
        try:
            user = await db.users.find_one({"_id": ObjectId(user_id)})
            if user and user.get("business_type") == "buyer":
                # Buyers only see their own tenders
                query["buyer_id"] = user_id
        except:
            pass
    
    tenders = await db.tenders.find(query).to_list(100)
    
    return {"tenders": serialize_doc(tenders)}

@api_router.get("/tenders/{tender_id}")
async def get_tender(tender_id: str):
    """Get tender details with all bids"""
    tender = await db.tenders.find_one({"_id": ObjectId(tender_id)})
    if not tender:
        raise HTTPException(status_code=404, detail="Tender not found")
    
    return {"tender": serialize_doc(tender)}

@api_router.post("/tenders/bid")
async def place_tender_bid(bid_data: TenderBid, user_id: str):
    """Seller accepts order (with quality check pending)"""
    user = await db.users.find_one({"_id": ObjectId(user_id)})
    if not user:
        raise HTTPException(status_code=404, detail="User not found")
    
    if user.get("business_type") != "seller":
        raise HTTPException(status_code=403, detail="Only sellers can accept orders")
    
    tender = await db.tenders.find_one({"_id": ObjectId(bid_data.tender_id)})
    if not tender:
        raise HTTPException(status_code=404, detail="Tender not found")
    
    if tender["ends_at"] < datetime.utcnow():
        raise HTTPException(status_code=400, detail="Tender has ended")
    
    # Calculate total already accepted quantity from all sellers (only non-rejected bids)
    total_accepted = 0
    for existing_bid in tender.get("bids", []):
        if existing_bid.get("status") != "rejected":
            total_accepted += existing_bid.get("quantity_accepted", 0)
    
    remaining_quantity = tender["quantity_mt"] - total_accepted
    
    if remaining_quantity <= 0:
        raise HTTPException(status_code=400, detail="This tender has been fully accepted. No more quantity available.")
    
    # Validate quantity doesn't exceed remaining
    quantity_to_accept = bid_data.quantity_accepted or remaining_quantity
    if quantity_to_accept > remaining_quantity:
        raise HTTPException(status_code=400, detail=f"Only {remaining_quantity} MT remaining. Cannot accept {quantity_to_accept} MT.")
    
    if quantity_to_accept <= 0:
        raise HTTPException(status_code=400, detail="Quantity must be greater than 0")
    
    bid = {
        "bidder_id": user_id,
        "bidder_name": user["company_name"],
        "rate_per_kg": bid_data.rate_per_kg,
        "quantity_accepted": quantity_to_accept,
        "delivery_timeline": bid_data.delivery_timeline,
        "bid_time": datetime.utcnow(),
        "status": "quality_check",  # Pending admin approval
        "admin_notes": None
    }
    
    await db.tenders.update_one(
        {"_id": ObjectId(bid_data.tender_id)},
        {"$push": {"bids": bid}}
    )
    
    # Broadcast to all connected clients
    await manager.broadcast(bid_data.tender_id, {
        "type": "new_bid",
        "tender_id": bid_data.tender_id,
        "bid": serialize_doc(bid)
    })
    
    # Send push notification to the buyer that their order was accepted
    await send_notification_to_user(
        user_id=tender["buyer_id"],
        title="Order Accepted!",
        body=f"{user['company_name']} accepted {quantity_to_accept} MT of {tender['variety']} @ ₹{tender['buyer_rate']}/kg",
        data={
            "type": "order_accepted",
            "tender_id": bid_data.tender_id,
            "seller_name": user["company_name"],
            "quantity": quantity_to_accept
        }
    )
    
    return {"success": True, "message": f"Order accepted for {quantity_to_accept} MT! Awaiting quality check approval."}

