# Simple admin credentials (for MVP - should be in database in production)
ADMIN_CREDENTIALS = {
    "admin@agrich.com": "admin123"
}

@api_router.post("/admin/login")
async def admin_login(credentials: AdminLogin):
    """Admin login"""
    if credentials.email in ADMIN_CREDENTIALS and ADMIN_CREDENTIALS[credentials.email] == credentials.password:
        # In production, generate proper JWT token
        token = f"admin_token_{credentials.email}"
        return {
            "success": True,
            "token": token,
            "admin": {"email": credentials.email, "role": "admin"}
        }
    raise HTTPException(status_code=401, detail="Invalid credentials")

@api_router.get("/admin/dashboard/stats")
async def get_dashboard_stats():
    """Get platform statistics"""
    total_users = await db.users.count_documents({})
    total_buyers = await db.users.count_documents({"business_type": "buyer"})
    total_sellers = await db.users.count_documents({"business_type": "seller"})
    
    active_tenders = await db.tenders.count_documents({
        "status": "active",
        "ends_at": {"$gt": datetime.utcnow()}
    })
    
    active_auctions = await db.auctions.count_documents({
        "status": "active",
        "ends_at": {"$gt": datetime.utcnow()}
    })
    
    pending_kyc = await db.users.count_documents({"kyc_status": {"$in": ["pending", "submitted"]}})
    
    return {
        "total_users": total_users,
        "total_buyers": total_buyers,
        "total_sellers": total_sellers,
        "active_tenders": active_tenders,
        "active_auctions": active_auctions,
        "pending_kyc": pending_kyc
    }

@api_router.get("/admin/users")
async def get_all_users(skip: int = 0, limit: int = 50):
    """Get all users for admin"""
    users = await db.users.find().skip(skip).limit(limit).to_list(limit)
    total = await db.users.count_documents({})
    return {
        "users": serialize_doc(users),
        "total": total
    }

@api_router.get("/admin/kyc/pending")
async def get_pending_kyc():
    """Get all pending KYC submissions"""
    users = await db.users.find({"kyc_status": {"$in": ["pending", "submitted"]}}).to_list(100)
    
    result = []
    for user in users:
        kyc_doc = await db.kyc_documents.find_one({"user_id": str(user["_id"])})
        result.append({
            "user": serialize_doc(user),
            "kyc": serialize_doc(kyc_doc) if kyc_doc else None
        })
    
    return {"pending_kyc": result}

@api_router.post("/admin/kyc/approve")
async def approve_kyc(approval: KYCApproval):
    """Approve or reject KYC"""
    await db.users.update_one(
        {"_id": ObjectId(approval.user_id)},
        {
            "$set": {
                "kyc_status": approval.status,
                "verified": approval.status == "approved"
            }
        }
    )
    
    await db.kyc_documents.update_one(
        {"user_id": approval.user_id},
        {"$set": {"status": approval.status, "admin_notes": approval.notes}}
    )
    
    return {"success": True, "message": f"KYC {approval.status}"}

@api_router.post("/admin/users/suspend")
async def suspend_user(suspension: UserSuspension):
    """Suspend or activate user"""
    await db.users.update_one(
        {"_id": ObjectId(suspension.user_id)},
        {"$set": {"suspended": suspension.suspended, "suspension_reason": suspension.reason}}
    )
    
    return {"success": True, "message": "User status updated"}

@api_router.get("/admin/users/pending")
async def get_pending_users():
    """Get all users pending approval"""
    users = await db.users.find({"approved": {"$ne": True}}).to_list(100)
    return {"pending_users": serialize_doc(users)}

@api_router.post("/admin/users/approve")
async def approve_user(user_id: str, approved: bool = True):
    """Approve or reject a user"""
    result = await db.users.update_one(
        {"_id": ObjectId(user_id)},
        {"$set": {"approved": approved}}
    )
    
    if result.modified_count == 0:
        raise HTTPException(status_code=404, detail="User not found")
    
    status = "approved" if approved else "rejected"
    
    # Send push notification to user about their approval status
    if approved:
        await send_notification_to_user(
            user_id=user_id,
            title="Account Approved!",
            body="Your Agrich account has been approved. You can now start trading!",
            data={"type": "account_approved"}
        )
    else:
        await send_notification_to_user(
            user_id=user_id,
            title="Account Status Update",
            body="Your Agrich account registration was not approved. Please contact support.",
            data={"type": "account_rejected"}
        )
    
    return {"success": True, "message": f"User {status} successfully"}

