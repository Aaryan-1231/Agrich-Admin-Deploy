@api_router.post("/admin/mandi/update")
async def update_mandi_price(state: str, mandi: str, variety: str, price: float):
    """Add or update mandi price"""
    # Check if this mandi entry already exists
    existing = await db.mandi_prices.find_one({
        "state": state,
        "mandi": mandi,
        "variety": variety
    })
    
    price_data = {
        "state": state,
        "mandi": mandi,
        "variety": variety,
        "price": price,
        "date": datetime.utcnow().strftime("%d/%m/%Y"),
        "updated_at": datetime.utcnow()
    }
    
    if existing:
        await db.mandi_prices.update_one(
            {"_id": existing["_id"]},
            {"$set": price_data}
        )
        return {"success": True, "message": "Mandi price updated"}
    else:
        await db.mandi_prices.insert_one(price_data)
        return {"success": True, "message": "Mandi price added"}

@api_router.get("/admin/mandi/all")
async def get_all_mandi_prices():
    """Get all mandi prices for admin"""
    prices = await db.mandi_prices.find().sort("updated_at", -1).to_list(100)
    return {"prices": serialize_doc(prices)}

@api_router.delete("/admin/mandi/{price_id}")
async def delete_mandi_price(price_id: str):
    """Delete a mandi price entry"""
    result = await db.mandi_prices.delete_one({"_id": ObjectId(price_id)})
    if result.deleted_count == 0:
        raise HTTPException(status_code=404, detail="Price entry not found")
    return {"success": True, "message": "Mandi price deleted"}

@api_router.get("/admin/transactions/pending")
async def get_pending_transactions():
    """Get all pending quality check transactions"""
    # Find all tenders with pending acceptances
    tenders = await db.tenders.find({}).to_list(1000)
    
    pending_transactions = []
    for tender in tenders:
        if tender.get("bids"):
            for bid in tender["bids"]:
                if bid.get("status") == "quality_check":
                    # Get buyer info
                    buyer = await db.users.find_one({"_id": ObjectId(tender["buyer_id"])})
                    
                    pending_transactions.append({
                        "tender_id": str(tender["_id"]),
                        "tender_variety": tender["variety"],
                        "tender_size": tender["size"],
                        "buyer_name": tender.get("buyer_name"),
                        "buyer_phone": buyer.get("phone") if buyer else None,
                        "seller_name": bid["bidder_name"],
                        "seller_id": bid["bidder_id"],
                        "quantity": bid.get("quantity_accepted", tender["quantity_mt"]),
                        "rate": bid["rate_per_kg"],
                        "delivery_location": tender["delivery_location"],
                        "accepted_at": bid["bid_time"],
                        "bid_index": tender["bids"].index(bid)
                    })
    
    return {"pending_transactions": serialize_doc(pending_transactions)}

@api_router.post("/admin/transactions/approve")
async def approve_transaction(tender_id: str, bid_index: int, approved: bool, notes: str = None):
    """Approve or reject a transaction"""
    tender = await db.tenders.find_one({"_id": ObjectId(tender_id)})
    if not tender:
        raise HTTPException(status_code=404, detail="Tender not found")
    
    if bid_index >= len(tender.get("bids", [])):
        raise HTTPException(status_code=400, detail="Invalid bid index")
    
    bid = tender["bids"][bid_index]
    
    # Update the specific bid's status
    new_status = "approved" if approved else "rejected"
    update_path = f"bids.{bid_index}.status"
    notes_path = f"bids.{bid_index}.admin_notes"
    
    await db.tenders.update_one(
        {"_id": ObjectId(tender_id)},
        {"$set": {
            update_path: new_status,
            notes_path: notes
        }}
    )
    
    # Send push notifications to both buyer and seller about quality check result
    seller_id = bid.get("bidder_id")
    buyer_id = tender.get("buyer_id")
    variety = tender.get("variety", "")
    quantity = bid.get("quantity_accepted", tender.get("quantity_mt", 0))
    
    if approved:
        # Notify seller
        await send_notification_to_user(
            user_id=seller_id,
            title="Quality Check Approved!",
            body=f"Your {quantity} MT of {variety} has passed quality check. Trade confirmed!",
            data={
                "type": "quality_check_approved",
                "tender_id": tender_id
            }
        )
        # Notify buyer
        await send_notification_to_user(
            user_id=buyer_id,
            title="Quality Check Approved!",
            body=f"{quantity} MT of {variety} has passed quality check. Trade confirmed!",
            data={
                "type": "quality_check_approved",
                "tender_id": tender_id
            }
        )
    else:
        # Notify seller
        await send_notification_to_user(
            user_id=seller_id,
            title="Quality Check Failed",
            body=f"Your {quantity} MT of {variety} did not pass quality check.{' Reason: ' + notes if notes else ''}",
            data={
                "type": "quality_check_rejected",
                "tender_id": tender_id
            }
        )
        # Notify buyer
        await send_notification_to_user(
            user_id=buyer_id,
            title="Quality Check Failed",
            body=f"{quantity} MT of {variety} from a seller did not pass quality check.",
            data={
                "type": "quality_check_rejected",
                "tender_id": tender_id
            }
        )
    
    return {"success": True, "message": f"Transaction {new_status}"}

